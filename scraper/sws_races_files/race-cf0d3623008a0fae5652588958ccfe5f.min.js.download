rred();var kart_engine_default=[];$.ajax({type:"GET",url:sws.config.baseUrlLang+'tracks/get_engines/'+parseInt(id_track),success:function(res){var kartEngineSelect=$('#race-form select[name="id_kart_engine"]');if(res.data&&Array.isArray(res.data)){if($.fn.select2&&kartEngineSelect.data('select2')){kartEngineSelect.select2('destroy')}kartEngineSelect.find('option[value!=""]').remove();$.each(res.data,function(index,row){kart_engine_default.push(row.id)});kartEngineSelect.prop('disabled',false);if(id_kart_engine){kartEngineSelect.select().val(id_kart_engine)}else{kartEngineSelect.select().val(null)}}else{kartEngineSelect.prop('disabled',true)}sws.front.select2Helper.init('#race-form select[name="id_kart_engine"]');deferred.resolve(kart_engine_default)},error:function(){deferred.resolve([])}});return deferred.promise()}};