if(!sws)var sws={};sws.language={parser:function(str,data){var parsed=str;for(x in data)parsed=parsed.replace('%'+x+'%',data[x]);return parsed}};sws.lang={drivers:"Piloti",teams:"Team",tracks:"Circuiti",ghostDriver:"Ghost driver",ghostTeam:"Ghost team",typeahead:{driver:{footer:"Puoi cercare per <strong>cognome</strong>, <strong>nome</strong>, <strong>identificativo</strong>, <strong>città</strong>...<br />Se non puoi trovare il pilota, cerca quello successivo."},team:{footer:"Puoi cercare per <strong>nome del team</strong>, <strong>identificativo</strong>, <strong>paese</strong>...<br />Se non puoi trovare il team, cerca quello successivo."},message_receiver:{noResultDesc:"Puoi cercare per <strong>cognome</strong>, <strong>nome</strong>, <strong>nome del team</strong>, <strong>nome del circuito</strong>, <strong>identificativo</strong>, <strong>città</strong>..."}},confirm:{del:{title:"Deletion",message:"Sei sicuro di voler cancellare <strong>%val%</strong>?"},remove:{title:"Rimuovi",message:"Sei sicuro di voler rimuovere <strong>%val%</strong>?"},leave:{title:"Permesso",message:"Sei sicuro di voler lasciare <strong>%val%</strong>?"},add:{title:"Aggiungi",message:"Sei sicuro di voler aggiungere <strong>%val%</strong>?"},invit:{title:"Invito",message:"Sei sicuro di voler invitare <strong>%val%</strong>?"}}};